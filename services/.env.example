# ── Hakky services config (copy to .env) ────────────────────────────────
NODE_ENV=development
PORT=8080

# Chain (Sepolia testnet by default — never point at mainnet in this phase)
CHAIN_ID=11155111
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Signer for services that WRITE to chain (attestor / reserve updater / verifier).
# Dev key only — leave blank for the read-only API. Production: KMS/HSM + multisig.
SIGNER_PRIVATE_KEY=

# Deployed contract addresses (fill after: contracts/ -> hardhat deploy --network sepolia)
ADDR_CLEAN_BTC=
ADDR_RESERVE_ORACLE=
ADDR_ATTESTATION_REGISTRY=
ADDR_COMPLIANCE_POLICY=
ADDR_RESERVE_VAULT=

# Postgres (audit log + job state)
DATABASE_URL=postgres://hakky:hakky@localhost:5432/hakky

# External integrations (stubbed in Phase 1)
SCREENING_PROVIDER=stub

# reserve-oracle keeper — publishes the stubbed custody balance to ReserveOracle
RESERVE_ORACLE_CRON=*/5 * * * *
CUSTODY_BALANCE_SATS=0            # BTC custody figure in sats; 0 disables publishing
RESERVE_REPORT_URI=https://api.hakky.xyz/reports/reserve-latest.json

# attestation-service (POST /screen)
ATTESTATION_PORT=8081
ATTESTATION_TTL_SECONDS=0         # 0 => contract defaultTtl (90 days)
SANCTIONED_ADDRESSES=            # comma-separated demo sanctions list

# orchestrator (POST /deposit + redeem watcher)
ORCHESTRATOR_PORT=8082
