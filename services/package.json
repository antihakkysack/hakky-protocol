{
  "name": "@hakky/services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hakky Protocol off-chain services: proof-of-reserves API, attestation, reserve oracle, mint/redeem orchestration.",
  "license": "MIT",
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "start:api": "tsx src/api/server.ts",
    "start:attestation": "tsx src/attestation/worker.ts",
    "start:reserve-oracle": "tsx src/reserve-oracle/cron.ts",
    "start:orchestrator": "tsx src/orchestrator/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
