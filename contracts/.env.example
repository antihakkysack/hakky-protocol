# Copy to .env and fill in for testnet/mainnet deploys.
# NEVER commit a real .env — it is gitignored.

# RPC endpoint for the target network (e.g. Alchemy/Infura Sepolia URL)
SEPOLIA_RPC_URL=

# Private key of a funded deployer account (testnet only for now)
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Set to "true" to print a gas report when running tests
REPORT_GAS=false
